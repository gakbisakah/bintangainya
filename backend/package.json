{
  "name": "bintangai-backend",
  "version": "1.0.0",
  "description": "Supabase Backend Configuration",
  "scripts": {
    "deploy:all": "supabase functions deploy",
    "deploy:ai-tutor": "supabase functions deploy ai-tutor --no-verify-jwt",
    "deploy:summarize": "supabase functions deploy summarize --no-verify-jwt",
    "set:secrets": "supabase secrets set --env-file .env"
  },
  "devDependencies": {
    "supabase": "^2.98.2"
  }
}
